# ============================================================
# nginx_lb.conf.j2 — Nginx Load Balancer config
# Duoc sinh ra tu: roles/nginx_service/templates/nginx_lb.conf.j2
#
# Bien su dung:
#   groups['web']   : danh sach tat ca web nodes
#   lb_skip_hosts   : (optional) list node can exclude khoi upstream
#                     vi du: ["node3"]  khi dang update node3
# ============================================================

upstream flask_cluster {
    # Round-robin (mac dinh), keepalive de reuse connection
{% for host in groups['web'] %}
{% if host not in (lb_skip_hosts | default([])) %}
    server {{ hostvars[host]['ansible_host'] }}:{{ webapp_host_port }} max_fails=2 fail_timeout=10s weight=1;
{% endif %}
{% endfor %}
    keepalive 16;
}

server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log;

    # Health check endpoint cho LB chinh no
    location /lb-status {
        stub_status on;
        allow 127.0.0.1;
        allow 192.168.80.0/24;
        deny all;
    }

    location / {
        proxy_pass         http://flask_cluster;
        proxy_http_version 1.1;
        proxy_set_header   Connection        "";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Host  $host;
        proxy_redirect     off;
        proxy_connect_timeout 10s;
        proxy_read_timeout    30s;
        proxy_next_upstream   error timeout http_502 http_503 http_504;
    }
}
